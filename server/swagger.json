{
  "openapi": "3.0.3",
  "info": {
    "title": "Smart Emergency Response System API",
    "description": "Real-time accident detection and emergency alert system. Monitors sensor data from IoT devices, detects accidents based on acceleration force, and broadcasts emergency alerts via WebSocket.",
    "version": "1.0.0",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "https://smart-emergency-response-system-2-c6wy.onrender.com",
      "description": "Production server (Render)"
    },
    {
      "url": "http://localhost:4000",
      "description": "Local development server"
    }
  ],
  "tags": [
    {
      "name": "Health",
      "description": "Server health and status monitoring"
    },
    {
      "name": "Sensor Data",
      "description": "Ingest sensor readings and detect accidents"
    },
    {
      "name": "WebSocket",
      "description": "Real-time emergency alerts (Socket.IO)"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "summary": "Root endpoint",
        "description": "Redirects to the health check endpoint (/api/health)",
        "operationId": "root",
        "responses": {
          "302": {
            "description": "Redirect to /api/health"
          }
        }
      },
      "head": {
        "summary": "Health probe",
        "description": "Returns 200 OK for uptime monitoring (Render, load balancers)",
        "operationId": "rootHead",
        "responses": {
          "200": {
            "description": "Server is running"
          }
        }
      }
    },
    "/api/health": {
      "get": {
        "tags": ["Health"],
        "summary": "Health check",
        "description": "Returns server uptime and database connectivity status. Use this to verify the API and database are operational.",
        "operationId": "getHealth",
        "responses": {
          "200": {
            "description": "Server and database are healthy",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                },
                "example": {
                  "status": "ok",
                  "uptime": 1234.56,
                  "database": "connected"
                }
              }
            }
          },
          "503": {
            "description": "Database is unreachable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                },
                "example": {
                  "status": "degraded",
                  "uptime": 1234.56,
                  "database": "disconnected"
                }
              }
            }
          }
        }
      }
    },
    "/api/sensor-data": {
      "post": {
        "tags": ["Sensor Data"],
        "summary": "Ingest sensor data",
        "description": "Submit sensor readings from IoT devices. The system calculates acceleration force and detects accidents. If force exceeds threshold (default 30) for confirmation window (default 3s), an incident is created and emergency alert is broadcast via WebSocket. Rate limited to 30 requests per 60s per IP.",
        "operationId": "ingestSensorData",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SensorDataRequest"
              },
              "examples": {
                "normal-reading": {
                  "summary": "Normal driving conditions",
                  "value": {
                    "acceleration": {
                      "x": 0.1,
                      "y": -0.2,
                      "z": 9.8
                    },
                    "location": {
                      "lat": 37.7749,
                      "lng": -122.4194
                    },
                    "timestamp": 1704067200000,
                    "device_id": "vehicle-001"
                  }
                },
                "accident-detected": {
                  "summary": "Accident-level force (force > 60)",
                  "value": {
                    "acceleration": {
                      "x": 35.5,
                      "y": -42.3,
                      "z": 15.7
                    },
                    "location": {
                      "lat": 37.7749,
                      "lng": -122.4194
                    },
                    "timestamp": 1704067200000,
                    "device_id": "vehicle-001"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "No incident detected",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SensorDataResponseNoIncident"
                }
              }
            }
          },
          "201": {
            "description": "Emergency incident detected and broadcast",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SensorDataResponseIncident"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationError"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded (30 requests per 60s)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RateLimitError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": ["ok", "degraded"],
            "description": "Overall health status"
          },
          "uptime": {
            "type": "number",
            "description": "Server uptime in seconds"
          },
          "database": {
            "type": "string",
            "enum": ["connected", "disconnected"],
            "description": "Database connection status"
          }
        },
        "required": ["status", "uptime", "database"]
      },
      "Acceleration": {
        "type": "object",
        "properties": {
          "x": {
            "type": "number",
            "description": "Acceleration on X axis (m/s²)"
          },
          "y": {
            "type": "number",
            "description": "Acceleration on Y axis (m/s²)"
          },
          "z": {
            "type": "number",
            "description": "Acceleration on Z axis (m/s²)"
          }
        },
        "required": ["x", "y", "z"]
      },
      "Location": {
        "type": "object",
        "properties": {
          "lat": {
            "type": "number",
            "minimum": -90,
            "maximum": 90,
            "description": "Latitude (-90 to 90)"
          },
          "lng": {
            "type": "number",
            "minimum": -180,
            "maximum": 180,
            "description": "Longitude (-180 to 180)"
          }
        },
        "required": ["lat", "lng"]
      },
      "SensorDataRequest": {
        "type": "object",
        "properties": {
          "acceleration": {
            "$ref": "#/components/schemas/Acceleration"
          },
          "location": {
            "$ref": "#/components/schemas/Location"
          },
          "timestamp": {
            "type": "number",
            "description": "Unix timestamp in milliseconds"
          },
          "device_id": {
            "type": "string",
            "description": "Optional device identifier (for cooldown tracking)"
          }
        },
        "required": ["acceleration", "location", "timestamp"]
      },
      "SensorDataResponseNoIncident": {
        "type": "object",
        "properties": {
          "detected": {
            "type": "boolean",
            "example": false
          },
          "force": {
            "type": "number",
            "description": "Calculated acceleration force (magnitude)"
          },
          "cooldown": {
            "type": "boolean",
            "description": "Present if alert was suppressed due to cooldown"
          },
          "message": {
            "type": "string",
            "enum": ["Alert suppressed (cooldown active).", "No incident detected."]
          }
        },
        "required": ["detected", "force", "message"]
      },
      "Incident": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique incident ID"
          },
          "type": {
            "type": "string",
            "example": "ACCIDENT"
          },
          "severity": {
            "type": "string",
            "enum": ["MODERATE", "HIGH", "CRITICAL"],
            "description": "Based on force: MODERATE (30-44), HIGH (45-59), CRITICAL (60+)"
          },
          "acceleration": {
            "type": "number",
            "description": "Force magnitude at detection"
          },
          "latitude": {
            "type": "number"
          },
          "longitude": {
            "type": "number"
          },
          "deviceId": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "type": "string",
            "example": "NEW"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "SensorDataResponseIncident": {
        "type": "object",
        "properties": {
          "detected": {
            "type": "boolean",
            "example": true
          },
          "force": {
            "type": "number"
          },
          "incident": {
            "$ref": "#/components/schemas/Incident"
          },
          "message": {
            "type": "string",
            "example": "Emergency incident detected and broadcast."
          }
        },
        "required": ["detected", "force", "incident", "message"]
      },
      "ValidationError": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Invalid data."
          },
          "details": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "field": {
                  "type": "string"
                },
                "issue": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "RateLimitError": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Too many requests. Please try again later."
          }
        }
      },
      "RouteNotFoundError": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Route not found."
          }
        }
      },
      "EmergencyAlert": {
        "type": "object",
        "description": "WebSocket event payload for emergency alerts",
        "properties": {
          "id": {
            "type": "string",
            "description": "Incident ID"
          },
          "type": {
            "type": "string",
            "example": "ACCIDENT"
          },
          "severity": {
            "type": "string",
            "enum": ["MODERATE", "HIGH", "CRITICAL"]
          },
          "force": {
            "type": "number",
            "description": "Acceleration force magnitude"
          },
          "location": {
            "$ref": "#/components/schemas/Location"
          },
          "deviceId": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "type": "string",
            "example": "NEW"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  },
  "x-webhooks": {
    "emergency-alert": {
      "post": {
        "summary": "Emergency Alert (WebSocket)",
        "description": "Real-time emergency alert broadcast via Socket.IO when an accident is detected",
        "tags": ["WebSocket"],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EmergencyAlert"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Alert received by connected clients"
          }
        }
      }
    }
  }
}
